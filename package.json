{
  "name": "ai-sales-agent",
  "version": "0.1.0",
  "description": "Multi-channel AI sales agent: WhatsApp/Email/Voice - qualifies leads, books calls",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "db:generate": "tsx ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "tsx ./node_modules/drizzle-kit/bin.cjs studio",
    "test": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/cookie": "^11.0.0",
    "fastify-plugin": "^5.0.0",
    "drizzle-orm": "^0.39.0",
    "pg": "^8.13.0",
    "ioredis": "^5.4.0",
    "bullmq": "^5.30.0",
    "zod": "^3.24.0",
    "@google/generative-ai": "^0.24.0",
    "resend": "^4.1.0",
    "twilio": "^5.4.0",
    "@nangohq/node": "^0.42.0",
    "papaparse": "^5.4.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "drizzle-kit": "^0.30.0",
    "vitest": "^3.0.0",
    "pino-pretty": "^13.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/papaparse": "^5.3.0"
  }
}
