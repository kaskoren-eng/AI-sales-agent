# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://dev:dev@localhost:5432/ai_sales_agent

# Redis
REDIS_URL=redis://localhost:6379

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-key-here

# JWT
JWT_SECRET=your-jwt-secret-here

# Lead intake webhooks
META_APP_SECRET=
LEAD_WEBHOOK_SECRET=

# App base URL (for Twilio callback URLs etc)
BASE_URL=http://localhost:3000

# Channels - WhatsApp (UChat)
UCHAT_WEBHOOK_SECRET=
UCHAT_API_TOKEN=

# Channels - Email (Resend)
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=sales@yourdomain.com

# Channels - Voice (Twilio + ElevenLabs)
TWILIO_ACCOUNT_SID=AC
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Scheduling (Trafft)
TRAFFT_SUBDOMAIN=
TRAFFT_EMAIL=
TRAFFT_PASSWORD=
TRAFFT_SERVICE_ID=your-service-uuid-here
TRAFFT_EMPLOYEE_ID=your-employee-uuid-here

# AI (Google Gemini)
GOOGLE_AI_API_KEY=
AI_MODEL=gemini-2.5-flash

# Integrations - Nango
NANGO_SECRET_KEY=

# Integrations - Google Sheets
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS
CORS_ORIGINS=http://localhost:3001
